# Amazon OneLink "home" tag (public — affiliate-link decoration is client-side).
# Once OneLink is configured in Associates, Amazon auto-routes each shopper to
# their local store with the mapped tag (e.g. US -> thebbqatlasus-20). Defaults
# to thebbqatlas-21 if unset.
NEXT_PUBLIC_AMAZON_ONELINK_TAG=thebbqatlas-21
# Dalstrong global affiliate ref (single program). Defaults to bbqatlas.
NEXT_PUBLIC_DALSTRONG_REF=bbqatlas